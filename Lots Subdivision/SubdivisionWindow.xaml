<Window x:Class="Lots_Subdivision.SubdivisionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AutoCAD 2025 - Smart Subdivision Pro" Height="650" Width="450"
        Background="#1E1E1E" WindowStyle="ThreeDBorderWindow" ResizeMode="NoResize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,5,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444444"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5,3"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="30"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Smart Subdivision Pro" FontSize="24" FontWeight="Bold" Foreground="#007ACC"/>
            <TextBlock Text="AutoCAD 2025 .NET 8.0 Edition" Foreground="#666666"/>
        </StackPanel>

        <!-- Main Form -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                
                <!-- Subdivision Mode Section -->
                <TextBlock Text="Subdivision Mode" FontWeight="SemiBold" Foreground="White" Margin="0,0,0,10"/>
                <ComboBox x:Name="ModeCombo" Margin="0,0,0,15" SelectedIndex="0">
                    <ComboBoxItem Content="Single Lot (Area Engine)"/>
                    <ComboBoxItem Content="Fixed Depth Subdivision"/>
                    <ComboBoxItem Content="Fixed Width Subdivision"/>
                    <ComboBoxItem Content="Batch Subdivision (Multi-Lot)"/>
                    <ComboBoxItem Content="Interactive Conflict Resolver"/>
                    <ComboBoxItem Content="Proportional Optimizer"/>
                    <ComboBoxItem Content="Priority-Based Solver"/>
                </ComboBox>

                <Separator Background="#333333" Margin="0,5,0,15"/>

                <!-- Parameters Section -->
                <TextBlock Text="Target Area (m²)" />
                <TextBox x:Name="TxtArea" Text="450.0"/>

                <TextBlock Text="Desired Frontage Width (m)" />
                <TextBox x:Name="TxtWidth" Text="15.0"/>

                <TextBlock x:Name="LblDepth" Text="Desired Lot Depth (m)" />
                <TextBox x:Name="TxtDepth" Text="30.0"/>

                <TextBlock Text="Side Boundary Angle (deg)" />
                <TextBox x:Name="TxtAngle" Text="90.0"/>

                <!-- Extra Batch Params (Only visible in Batch mode) -->
                <StackPanel x:Name="BatchPanel" Visibility="Collapsed">
                    <TextBlock Text="Number of Lots" />
                    <TextBox x:Name="TxtLots" Text="5"/>
                </StackPanel>

                <!-- Extra Priority Params (Only visible in Priority mode) -->
                <StackPanel x:Name="PriorityPanel" Visibility="Collapsed">
                    <TextBlock Text="Minimum Council Width (m)" />
                    <TextBox x:Name="TxtMinWidth" Text="10.0"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer / Run -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <Button Content="Initialize Subdivision" Height="50" FontSize="16" FontWeight="Bold" 
                    Background="#007ACC" Foreground="White" BorderThickness="0" Cursor="Hand"
                    Click="BtnRun_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <TextBlock Text="Select parent polyline and frontage after clicking." 
                       HorizontalAlignment="Center" Foreground="#666666" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
