<Window x:Class="Lots_Subdivision.SubdivisionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Subdivision Dashboard" Height="750" Width="450"
        Background="#1E1E1E" WindowStyle="ThreeDBorderWindow" Topmost="True" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#EEEEEE"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="5,4"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3E3E42"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#555555"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Smart Subdivision Pro" FontSize="22" FontWeight="Bold" Foreground="#007ACC"/>
            <TextBlock Text="AutoCAD 2025 Interactive Dashboard" Foreground="#888888"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border BorderBrush="#333333" BorderThickness="1" Padding="15" CornerRadius="4" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="CAD SELECTION" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,10"/>
                        <Button x:Name="BtnPickParent" Content="Pick Parent Parcel" Click="BtnPickParent_Click" Margin="0,0,0,5"/>
                        <Button x:Name="BtnPickFrontage" Content="Pick Frontage Segment" Click="BtnPickFrontage_Click" Margin="0,0,0,5"/>
                        <Button x:Name="BtnPickAngle" Content="Pick Side Angle (2 Points)" Click="BtnPickAngle_Click"/>
                        <TextBlock x:Name="TxtStatus" Text="Ready" Foreground="#66BB66" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="CONSTRAINT LOCKING" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,5"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <CheckBox x:Name="ChkLockArea" Content="Lock Area" IsChecked="True"/>
                    <CheckBox x:Name="ChkLockWidth" Content="Lock Width" Grid.Column="1"/>
                    <CheckBox x:Name="ChkLockDepth" Content="Lock Depth" Grid.Column="2"/>
                </Grid>

                <TextBlock Text="Target Area (m²)"/>
                <TextBox x:Name="TxtArea" Text="450.0"/>

                <TextBlock Text="Target Width (m)"/>
                <TextBox x:Name="TxtWidth" Text="15.0"/>

                <TextBlock Text="Target Depth (m)"/>
                <TextBox x:Name="TxtDepth" Text="30.0"/>

                <TextBlock Text="Side Boundary Angle (deg)"/>
                <TextBox x:Name="TxtAngle" Text="90.0"/>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="2" Content="EXECUTE SUBDIVISION" Height="50" FontWeight="Bold" 
                Background="#007ACC" BorderThickness="0" Margin="0,20,0,0" Click="BtnRun_Click"/>
    </Grid>
</Window>
